# Backblaze B2 credentials (required)
# Create an application key at https://secure.backblaze.com/app_keys.htm
B2_KEY_ID=your_key_id_here
B2_APPLICATION_KEY=your_application_key_here

# Data directory inside the container (optional — defaults to ./data next to the script)
# Only change this if you're mounting your data volume somewhere other than /app/data
# B2_DEDUP_DATA_DIR=/app/data

# Host drives map to the docker container for uploading (optional, defaults to ./data if unset)
# Change this to map your operating system's native drive format into the GUI's Upload feature.
# Mac: /Volumes
# Linux: /media  (or /mnt, or /run/media)
# Windows: D:\  (or whatever drive letter you use)
# HOST_DRIVES_PATH=/Volumes
